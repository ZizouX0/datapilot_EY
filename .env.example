# Server-side Anthropic API key for the AI-personalized roadmap feature.
# Used by api/roadmap.js (production) and the Vite dev middleware (npm run dev).
# NEVER prefix with VITE_ — that would expose it to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# Server-side key for the AI-personalized roadmap feature (api/roadmap.js +
# the Vite dev middleware). NEVER prefix with VITE_ — that exposes it to the browser.

# --- Google Gemini (default, free tier) ---
# Get a key at https://aistudio.google.com/apikey  (no credit card needed)
GEMINI_API_KEY=

# --- Optional: switch providers (any OpenAI-compatible endpoint) ---
# The code is provider-agnostic. To use Groq, OpenRouter, etc., set these:
# AI_API_KEY=...                                   # overrides GEMINI_API_KEY
# AI_BASE_URL=https://api.groq.com/openai/v1       # Groq
# AI_MODEL=llama-3.3-70b-versatile                 # Groq model
#   OpenRouter:  AI_BASE_URL=https://openrouter.ai/api/v1   AI_MODEL=google/gemini-2.0-flash-exp:free
#   Gemini (default): AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai   AI_MODEL=gemini-2.5-flash
